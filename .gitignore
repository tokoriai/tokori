# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dist-hosted
.wrangler
*.local
*.tsbuildinfo

# `scripts/` holds a mix of public pack-build helpers and local-only
# infra bootstrap scripts (DNS, deploy keys, Stripe, etc.). Default to
# ignoring everything in there, then whitelist the publishable pack
# builders. `build-yan-yin-pack.mjs` (commercial pack) and the infra
# scripts stay ignored.
scripts/*
!scripts/build-*-free-pack.cjs
!scripts/build-chinese-pack.mjs
!scripts/release-check.mjs
!scripts/release-local.mjs

# The Yan Yin pack is derived from a commercial textbook and is only
# distributed through the controlled cloud catalog / mobile app — never
# bundle it in the public open-source repo. (It stays on disk for those
# other builds; this just stops a stray `git add` from publishing it.)
packs/yan-yin-sprachpraxis.json

# Internal launch ops: checklist, press kit, draft social copy. Lives on
# disk for the maintainer; not part of the public open-source repo.
launch/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Safety net: the proprietary cloud backend lives in a separate
# private repo (`tokori-cloud` on the same disk). These entries
# are belt-and-suspenders so a stray `git add` from the wrong cwd
# can't leak Stripe keys / signing secrets even if someone drops
# the cloud repo as a subfolder of this one by accident.
.dev.vars
.env
.env.local
.env.production

# ── Rust / Tauri build output ────────────────────────────────────────
# `target/` is hundreds of MB of compiled crates per platform — never
# commit. `gen/` is generated by `tauri build` (codesigned bundles,
# platform-specific resources).
src-tauri/target
src-tauri/gen/schemas
src-tauri/WixTools


# ── Local databases / user data ──────────────────────────────────────
# The desktop's SQLite lives in the Tauri app data dir at runtime, but
# during dev you can end up with stray *.db files. Ignore them broadly
# so a misplaced one never lands in a commit.
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Test / coverage output ───────────────────────────────────────────
coverage
.nyc_output
*.lcov

# ── Coding-agent session data & local instructions ─────────────────────────────────
.claude
.cursor
.aider*
CLAUDE.md

# ── OS junk ──────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.icloud
mcp-server/dist/

# VitePress dev caches — auto-regenerated, should never be committed.
docs/.vitepress/cache
docs/.vitepress/dist

