# Frontend build-time config (Vite). Copy to `.env.local` to override.
#
# These are PUBLIC, build-time values — Vite inlines them into the client
# bundle, so never put secrets here. The desktop / local-first build needs
# none of them; they only matter for builds that exercise the optional
# Tokori Cloud account (OAuth, sync, managed AI).

# Cloud API base for dev builds. Point at a local cloud with
# http://localhost:3001, or leave unset for the default.
# VITE_CLOUD_API_BASE_URL=https://tokori.ai

# Cloudflare Turnstile *site* key (public, safe to expose) used by the
# sign-in captcha in hosted/cloud builds.
# VITE_TURNSTILE_SITE_KEY=
