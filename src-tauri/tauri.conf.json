{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tokori",
  "version": "0.1.0-alpha.2",
  "identifier": "ai.tokori.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Tokori",
        "width": 1320,
        "height": 980,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 14 }
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: http://127.0.0.1:* http://localhost:* ws: wss:; img-src 'self' data: blob: https: http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' blob:; font-src 'self' data:; media-src 'self' blob: data: https:; worker-src 'self' blob:; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://m.youtube.com"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:tokori.db"]
    },
    "updater": {
      "endpoints": [
        "https://github.com/tokoriai/tokori/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2NzNDREU2RUM2QjlBOTAKUldTUW1tdnM1czF6OW9DTTRmQy9QNUJxY0J0VzRBajc5c0t1eW9iZWtiWlA0eFlveHZIN1BtUTQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/hanzi-writer-data/*.json",
      "assets/hanzi-writer-data/ARPHICPL.TXT"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
